  "main": "server.js",
  "bin": {
    "hive-mcp-morph": "./server.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "agentic",
    "ai-agent",
    "ai-agents",
    "llm",
    "hive",
    "hive-civilization",
    "hivemorph",
    "polymorphic-agents",
    "agent-self-modification",
    "a2a",
    "agent-identity",
    "brood",
    "supermodel",
    "usdc",
    "base",
    "base-l2",
    "autonomous-agent",
    "agent-infrastructure",
    "agent-network",
    "real-rails",
    "on-chain-settlement"
  ],
  "author": "Steve Rotzin <steve@thehiveryiq.com> (https://www.thehiveryiq.com)",
  "license": "MIT",
  "homepage": "https://github.com/srotzin/hive-mcp-morph",
  "repository": {
    "type": "git",
    "url": "https://github.com/srotzin/hive-mcp-morph"
  },
  "engines": {
    "node": ">=18"
  },
