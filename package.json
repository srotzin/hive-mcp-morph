{
  "name": "hive-mcp-morph",
  "version": "1.0.2",
  "description": "MCP server for HiveMorph \u2014 public shim for the Hivemorph polymorphic agent runtime. Exposes the polymorphic audit log, identity index, supermodel directory, brood carousel, and approval queue. A2A-compatible, x402-gated. Real rails.",
